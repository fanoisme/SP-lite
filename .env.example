# Copy this file to .env.local (gitignored) and fill in your Supabase project's
# URL and anon/public key — Settings > API in the Supabase dashboard.
#
# The anon key is safe to ship to the browser: it has no privileges on its own,
# access is enforced by the Row Level Security policies in supabase/schema.sql.
# Never put the service_role key here or anywhere in this repo.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
